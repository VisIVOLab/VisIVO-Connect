VISIVO_APP_ENV=production
VISIVO_APP_NAME=VisIVO Connect
VISIVO_APP_VERSION=0.1.0
VISIVO_FRONTEND_BUILD=prod
VISIVO_HOST=0.0.0.0
VISIVO_PORT=8080
VISIVO_LOG_LEVEL=INFO

# Optional default dataset served when client does not provide datasetPath.
VISIVO_DATACUBE_PATH=
VISIVO_DATASET_ROOT=
VISIVO_STRICT_DATASET_PATH=1
VISIVO_FITS_CACHE_MAX_ENTRIES=2

# Optional auth tokens.
VISIVO_AUTH_TOKEN=
VISIVO_METRICS_TOKEN=

# Session lifecycle.
VISIVO_MAX_SESSIONS=16
VISIVO_IDLE_TIMEOUT_S=900
VISIVO_CLEANUP_INTERVAL_S=30

# CORS. Use a JSON list or comma-separated list in production.
VISIVO_ALLOWED_ORIGINS=[]

# WebRTC / ICE / TURN.
VISIVO_FORCE_RELAY_ONLY=0
VISIVO_ICE_GATHER_TIMEOUT_MS=300
VISIVO_ICE_GATHER_TIMEOUT_MS_RELAY=200
VISIVO_ICE_SERVERS='[{"urls":["stun:stun.l.google.com:19302"]}]'
VISIVO_CLIENT_ICE_SERVERS='[{"urls":["stun:stun.l.google.com:19302"]}]'

# Frontend/runtime defaults.
VISIVO_DEFAULT_TARGET_FPS=30
VISIVO_DEFAULT_BITRATE_MBPS=14
VISIVO_DEFAULT_INTERACTIVE_DOWNSAMPLE=1.6
VISIVO_DEFAULT_HQ_DETAIL_PRESET=sharp
VISIVO_WS_RECONNECT_BASE_DELAY_MS=1000
VISIVO_WS_RECONNECT_MAX_DELAY_MS=15000

# Renderer/runtime knobs already supported by the app.
VISIVO_STABILITY_MODE=0
VISIVO_VTK_RENDER_WINDOW=auto
VISIVO_SMART_MAPPER_MODE=raycast
VISIVO_VTK_MAIN_THREAD=
